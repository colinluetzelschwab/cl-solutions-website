# Auto-generated by _agency/scripts/migrate-env-to-keychain.sh
# Safe to commit — contains only Keychain lookup names, no secret values.
source "$HOME/.clsolutions/keychain-env.sh"

export_kc BLOB_READ_WRITE_TOKEN "cl-solutions-website-blob-read-write-token"
export_kc VERCEL_OIDC_TOKEN "cl-solutions-website-vercel-oidc-token"
export_kc DASHBOARD_PASSWORD "cl-solutions-website-dashboard-password"

# JARVIS Mail (IMAP read access to colin@clsolutions.dev — Hostpoint).
# Password lives in Keychain only. Public values inline.
export IMAP_USER="colin@clsolutions.dev"
export IMAP_HOST="imap.mail.hostpoint.ch"
export IMAP_PORT="993"
export_kc IMAP_PASSWORD "clsolutions-imap-password"
